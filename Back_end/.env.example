# Application Settings
PROJECT_NAME="Udyame AI"
API_V1_STR="/api/v1"

# Database Settings
# Replace with your actual credentials
DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/udyame_db"

# Redis Settings
REDIS_URL="redis://localhost:6379/0"

# AI Provider Keys (Replace with your keys)
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AI..."

# MinIO Settings
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET_NAME="udyame-exports"

# Security Settings
SECRET_KEY="generate-a-secure-secret-key-here"
ALGORITHM="HS256"
