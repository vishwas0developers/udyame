# Application Settings
PROJECT_NAME="Udyame AI"
API_V1_STR="/api/v1"

# Database Settings
# Replace with your actual credentials
DATABASE_URL="postgresql+psycopg2://postgres:postgres_password@localhost:5432/udyame_db"

# Redis Settings
REDIS_URL="redis://localhost:6379/0"

# AI Provider Keys (Replace with your keys)
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AI..."

# MinIO Settings
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET_NAME="udyame-exports"

# Security Settings
SECRET_KEY="generate-a-secure-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Settings
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5012/api/v1/auth/google/callback"
FRONTEND_URL="http://localhost:3000"
