# Application Settings
PROJECT_NAME="Udyame AI"
API_V1_STR="/api/v1"

# Database Settings
DATABASE_URL="postgresql+psycopg2://postgres:postgres_password@localhost:5432/udyame_db"

# Redis Settings
REDIS_URL="redis://localhost:6379/0"

# AI Provider Keys
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AI..."

# MinIO / S3 Settings
MINIO_ENDPOINT="localhost:9000"
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_SECURE=False  # Set to True for production with HTTPS

# Buckets
MINIO_BUCKET_DOCUMENTS="udyme-documents"
MINIO_BUCKET_TEMPLATES="udyme-templates"
MINIO_BUCKET_LOGS="udyme-audit-logs"

# Security Settings
SECRET_KEY="generate-a-secure-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# External Integrations
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5012/api/v1/auth/google/callback"
FRONTEND_URL="http://localhost:3000"
