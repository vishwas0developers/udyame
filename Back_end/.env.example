# --- CORE CONFIGURATION ---
PROJECT_NAME="Udyame AI"
API_V1_STR="/api/v1"
APP_MODE=BOTH  # Options: API, ADMIN, BOTH
FRONTEND_URL="http://localhost:3000"

# --- DATABASE (POSTGRES) ---
DATABASE_URL="postgresql+psycopg2://user:password@localhost:5432/dbname"

# --- SECURITY ---
# Generate a secure key using: python scripts/generate_secret.py
SECRET_KEY="REPLACE_WITH_SECURE_KEY"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379/0"

# --- STORAGE (MINIO / S3) ---
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_SECURE=False
MINIO_BUCKET_NAME="udyame-assets"

# --- PAYMENTS ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# --- AI PROVIDERS ---
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# --- MONITORING ---
SENTRY_DSN=""

# --- RATE LIMITING ---
RATE_LIMIT_PER_MINUTE=60

# --- OAUTH ---
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5014/api/v1/auth/google/callback"
